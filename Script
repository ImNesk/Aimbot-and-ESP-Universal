local function IsEnemy(p)
    if p == LP then return false end
    local a, b = LP.Team, p.Team
    if not a and not b then return true end
    if not a or  not b then return true end
    return a ~= b
end

local function Nearest()
    local best, bd = nil, math.huge
    local cx = Cam.ViewportSize.X * 0.5
    local cy = Cam.ViewportSize.Y * 0.5
    for _, p in ipairs(Players:GetPlayers()) do
        if IsEnemy(p) and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local hum  = p.Character:FindFirstChild("Humanoid")
            if root and hum and hum.Health > 0 then
                local sp, onScreen = Cam:WorldToViewportPoint(root.Position)
                if onScreen then
                    local d = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
                    if d < S.FOV and d < bd then bd=d; best=p end
                end
            end
        end
    end
    return best
end

local function GetPart(player, name)
    if not player or not player.Character then return nil end
    return player.Character:FindFirstChild(name)
end

