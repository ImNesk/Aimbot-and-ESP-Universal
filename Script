        if not dragging or i.UserInputType~=Enum.UserInputType.MouseMovement then return end
        local p = math.clamp((i.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
        local v = math.floor(minV+p*(maxV-minV))
        S[key]=v; fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,0,0.5,0)
        vl.Text=tostring(v)..suf
        if cb then cb(v) end
    end)
    Gap(4)
end

