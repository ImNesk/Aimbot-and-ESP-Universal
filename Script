--  HITBOX VISUAL
-- ══════════════════════════════════════════════
local HBStore   = {}
local lastHBOn  = false
local lastHBSty = S.HBStyle

local function RemoveHB(p)
    if not HBStore[p] then return end
    for _, v in ipairs(HBStore[p]) do
        if typeof(v)=="RBXScriptConnection" then v:Disconnect()
        elseif typeof(v)=="Instance" and v.Parent then v:Destroy() end
    end
    HBStore[p]=nil
end

local BONES={
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
}

local function DrawBoxHB(p)
    if not p.Character then return end
    local root=p.Character:FindFirstChild("HumanoidRootPart"); if not root then return end
    local bb=Instance.new("BillboardGui"); bb.Adornee=root; bb.Size=UDim2.new(0,56,0,88)
    bb.StudsOffset=Vector3.new(0,1.2,0); bb.AlwaysOnTop=true; bb.LightInfluence=0
    bb.ResetOnSpawn=false; bb.Parent=LP.PlayerGui
    local f=Instance.new("Frame"); f.Size=UDim2.new(1,0,1,0); f.BackgroundTransparency=1; f.Parent=bb; Crn(f,3)
    local s=Instance.new("UIStroke"); s.Color=C.RED; s.Thickness=1.5; s.Parent=f
    HBStore[p]={bb}
end

local function DrawSkeletonHB(p)
    if not p.Character then return end
    local char=p.Character; local objs,nodes={},{}
    for _,bone in ipairs(BONES) do
        local b1=char:FindFirstChild(bone[1]); local b2=char:FindFirstChild(bone[2])
        if b1 and b2 then
            local mid=Instance.new("Part"); mid.Size=Vector3.new(0.05,0.05,0.05)
            mid.Anchored=true; mid.CanCollide=false; mid.CastShadow=false
            mid.Transparency=1; mid.CFrame=CFrame.new((b1.Position+b2.Position)*0.5); mid.Parent=workspace
            local bb=Instance.new("BillboardGui"); bb.Adornee=mid; bb.Size=UDim2.new(0,5,0,5)
            bb.AlwaysOnTop=true; bb.LightInfluence=0; bb.Parent=LP.PlayerGui
            local dot=Instance.new("Frame"); dot.Size=UDim2.new(1,0,1,0)
            dot.BackgroundColor3=Color3.fromRGB(180,100,255); dot.BorderSizePixel=0; dot.Parent=bb; Crn(dot,3)
            table.insert(objs,mid); table.insert(objs,bb)
            table.insert(nodes,{part=mid,b1=bone[1],b2=bone[2]})
        end
    end
    local conn=RunService.RenderStepped:Connect(function()
        if not char.Parent then return end
        for _,n in ipairs(nodes) do
            local a=char:FindFirstChild(n.b1); local b=char:FindFirstChild(n.b2)
            if a and b and n.part.Parent then n.part.CFrame=CFrame.new((a.Position+b.Position)*0.5) end
        end
    end)
    table.insert(objs,conn); HBStore[p]=objs
end

local function RefreshHB()
    for _,p in ipairs(Players:GetPlayers()) do
        if IsEnemy(p) then
            RemoveHB(p)
            if S.HBOn and p.Character then
                if S.HBStyle=="Box" then DrawBoxHB(p) else DrawSkeletonHB(p) end
            end
        end
    end
end

Players.PlayerRemoving:Connect(function(p) RemoveESP(p); RemoveHB(p) end)

