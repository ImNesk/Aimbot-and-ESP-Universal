--  ESP  (BillboardGui parented to PlayerGui)
-- ══════════════════════════════════════════════
local ESPStore = {}

local function RemoveESP(p)
    if not ESPStore[p] then return end
    for _, v in ipairs(ESPStore[p]) do
        if typeof(v)=="Instance" and v.Parent then v:Destroy() end
    end
    ESPStore[p] = nil
end

local function BuildESP(p)
    if not p.Character then return end
    local root = p.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local bb = Instance.new("BillboardGui")
    bb.Name           = "AimESP"
    bb.Adornee        = root
    bb.Size           = UDim2.new(0,80,0,115)
    bb.StudsOffset    = Vector3.new(0,1.8,0)
    bb.AlwaysOnTop    = true
    bb.LightInfluence = 0
    bb.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    bb.ResetOnSpawn   = false
    bb.Parent         = LP.PlayerGui

    -- Main box
    local boxF = Instance.new("Frame")
    boxF.Name="Box"; boxF.Size=UDim2.new(1,0,1,0)
    boxF.BackgroundTransparency=1; boxF.BorderSizePixel=0; boxF.ZIndex=6; boxF.Parent=bb
    Crn(boxF,3)
    local bs=Instance.new("UIStroke"); bs.Color=C.ACCENT; bs.Thickness=1.5; bs.Parent=boxF

    ESPStore[p] = {bb}
end

local function TickESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsEnemy(p) then
            if S.ESPOn and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if not ESPStore[p] then BuildESP(p) end
                local objs = ESPStore[p]; if not objs then continue end
                local bb = objs[1]
                if not bb or not bb.Parent then
                    ESPStore[p]=nil; BuildESP(p)
                    objs=ESPStore[p]; if not objs then continue end
                    bb=objs[1]
                end
                local root=p.Character:FindFirstChild("HumanoidRootPart")
                if root then bb.Adornee=root end
                local box=bb:FindFirstChild("Box")
                if box then box.Visible=S.ESPBoxes end
            else
                RemoveESP(p)
            end
        end
    end
end

