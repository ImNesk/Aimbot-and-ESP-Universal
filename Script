local starTimer = 0
RunService.Heartbeat:Connect(function(dt)
    starTimer += dt
    if starTimer < 0.04 then return end
    starTimer = 0
    for _, sd in ipairs(starData) do
        sd.t += sd.spd * 0.04
        local alpha = (math.sin(sd.t)+1)/2
        local b = math.floor(sd.base*(0.25+0.75*alpha))
        sd.dot.BackgroundColor3 = Color3.fromRGB(b, b//3, math.min(255,b+80))
        sd.dot.BackgroundTransparency = 0.05+(1-alpha)*0.7
    end
end)

