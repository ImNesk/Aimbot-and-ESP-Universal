-- Picker row (futuristic segment control)
local function Picker(lbl, key, opts, cb)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1,0,0,36)
    row.BackgroundColor3 = C.BG2
    row.BackgroundTransparency = 0.08
    row.BorderSizePixel  = 0
    row.LayoutOrder      = LO()
    row.ZIndex           = 4
    row.Parent           = Scroll
    Crn(row, 8)
    Strk(row, C.FAINT, 0.8)

    local l = Lbl(row,lbl,12,C.TEXT,false,Enum.TextXAlignment.Left,5)
    l.Size     = UDim2.new(0.38,0,1,0)
    l.Position = UDim2.new(0,12,0,0)

    local bw = 0.56 / #opts
    local buttons = {}
    for i, opt in ipairs(opts) do
        local b = Instance.new("TextButton")
        b.Size             = UDim2.new(bw,-4,0,24)
        b.Position         = UDim2.new(0.42+bw*(i-1), 2, 0.5,-12)
        b.BorderSizePixel  = 0
        b.Text             = opt
        b.Font             = Enum.Font.GothamBold
        b.TextSize         = 11
        b.AutoButtonColor  = false
        b.ZIndex           = 6
        b.Parent           = row
        Crn(b, 5)
        buttons[i] = b
    end

    local function RefreshAll()
        for i, b in ipairs(buttons) do
            local on = S[key] == opts[i]
            b.BackgroundColor3 = on and C.ON_TRK or C.OFF_TRK
            b.TextColor3       = on and C.GLOW   or C.MUTED
            if on then
                pcall(function()
                    local g = b:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke",b)
                    g.Color = C.ACCENT; g.Thickness = 1
                end)
            else
                pcall(function()
                    local g = b:FindFirstChildOfClass("UIStroke")
                    if g then g:Destroy() end
                end)
            end
        end
    end
    RefreshAll()

    for i, b in ipairs(buttons) do
        b.MouseButton1Click:Connect(function()
            S[key] = opts[i]; RefreshAll()
            if cb then cb(opts[i]) end
        end)
    end
    Gap(4)
end

